# Database (Neon / Supabase)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?pgbouncer=true"
DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE"

# Admin JWT secret (random chuỗi dài, tự tạo bằng: openssl rand -base64 32)
ADMIN_JWT_SECRET="your-admin-jwt-secret-here"

# Cron secret (để bảo vệ endpoint cron trên Vercel)
CRON_SECRET="random-long-string"

SCRAPE_IMPORT_SECRET="your-scrape-import-secret-here"

# Python scraper config (dùng cho strava_club_scraper.py)
# STRAVA_SESSION_COOKIE không cần đặt ở đây — được lấy tự động từ DB qua API
# Admin cập nhật session mới tại: /admin/settings
STRAVA_CLUB_ID="2224942"
APP_BASE_URL="https://your-app.vercel.app"
CHALLENGE_ID="1"